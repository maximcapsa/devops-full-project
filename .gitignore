.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# Helm packaged dependencies (rebuilt by `helm dependency update`)
deploy/charts/ecommerce/charts/

# Kubeconfig fetched locally
kubeconfig
*.kubeconfig

# Local Claude personal instructions — not project content
claude.md
CLAUDE.md
