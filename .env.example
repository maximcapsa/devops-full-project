# Copy to .env for local docker-compose dev. NEVER commit a real .env.
# ── Shared ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Postgres (single instance, schema-per-service) ───────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=ecommerce
# DSN used by every service (schema is selected per-service via search_path/queries)
DATABASE_URL=postgres://app:devpassword@postgres:5432/ecommerce?sslmode=disable

# ── Kafka / Redpanda ─────────────────────────────────────────────────────────
KAFKA_BROKERS=redpanda:9092

# ── Per-service ports (gRPC + HTTP health/REST) ──────────────────────────────
PRODUCT_GRPC_PORT=50051
PRODUCT_HTTP_PORT=8081
ORDER_GRPC_PORT=50052
ORDER_HTTP_PORT=8082
INVENTORY_GRPC_PORT=50053
INVENTORY_HTTP_PORT=8083
PAYMENT_HTTP_PORT=8084
NOTIFICATION_GRPC_PORT=50055
NOTIFICATION_HTTP_PORT=8085
BFF_HTTP_PORT=8080

# ── BFF upstream gRPC addresses ──────────────────────────────────────────────
PRODUCT_GRPC_ADDR=product:50051
ORDER_GRPC_ADDR=order:50052
INVENTORY_GRPC_ADDR=inventory:50053
NOTIFICATION_GRPC_ADDR=notification:50055

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BFF_URL=http://localhost:8080
